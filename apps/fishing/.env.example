# Kopiera till apps/fishing/.env (checkas aldrig in) och fyll i vid FÖRSTA deploy.
# Admin-uppgifterna används bara av engångs-migreringen som skapar första admin-
# användaren i Öppen-driftfallet — de bakas aldrig in i imagen eller i labels.

# Första admin (skapas bara om e-posten inte redan finns i databasen).
JF_ADMIN_EMAIL=
JF_ADMIN_PASSWORD=

